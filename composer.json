{
    "name": "seu-usuario/csmlimpo",
    "description": "CSMLimpo completo, versão com UI de geração de testes para todas funções e documentação detalhada",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "ext-mysqli": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always"
    }
}
